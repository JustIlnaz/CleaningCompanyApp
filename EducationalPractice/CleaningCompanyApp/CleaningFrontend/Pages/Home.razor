@page "/"
@using CleaningFrontend.ApiRequests.Services
@using CleaningFrontend.ApiRequests.Model
@using Blazored.LocalStorage

<div class="home-container">
    <div class="hero-section">
        <h1>Платформа управления клининговой компанией</h1>
        <p>Автоматизация заказов, управление бригадами, контроль качества</p>
        @if (!IsAuthenticated)
        {
            <div class="hero-buttons">
                <a href="/register" class="btn-primary">Регистрация</a>
                <a href="/login" class="btn-secondary">Вход</a>
            </div>
        }
        else if (currentUser != null)
        {
            <div class="hero-buttons">
                <a href="@LandingPath" class="btn-primary">Перейти в @LandingTitle</a>
                <a href="/profile" class="btn-secondary">Профиль</a>
            </div>
        }
    </div>

    <div class="features-section">
        <div class="feature-card">
            <h3>Прием заказов</h3>
            <p>Быстрое оформление и планирование уборки</p>
        </div>
        <div class="feature-card">
            <h3>Управление бригадами</h3>
            <p>Контроль графиков и загрузки бригад</p>
        </div>
        <div class="feature-card">
            <h3>Контроль качества</h3>
            <p>Проверка по чек-листам и фотоотчеты</p>
        </div>
        <div class="feature-card">
            <h3>Учет материалов</h3>
            <p>Складской учет и оптимизация расходов</p>
        </div>
    </div>
</div>

@code {
    public bool IsAuthenticated { get; set; }
    private UserModel currentUser;
    private string LandingPath => currentUser?.Role_Id switch
    {
        1 => "/admin",
        2 => "/orders",
        3 => "/my-tasks",
        4 => "/my-orders",
        _ => "/profile"
    };
    private string LandingTitle => currentUser?.Role_Id switch
    {
        1 => "панель управления",
        2 => "заказы",
        3 => "мои задания",
        4 => "мои заказы",
        _ => "профиль"
    };

    protected override async Task OnInitializedAsync()
    {
        var token = await LocalStorage.GetItemAsync<string>("token");
        IsAuthenticated = !string.IsNullOrEmpty(token);
        if (IsAuthenticated)
        {
            currentUser = await LocalStorage.GetItemAsync<UserModel>("user");
        }
    }

    [Inject] protected ILocalStorageService LocalStorage { get; set; }
}
