@page "/login"
@using CleaningFrontend.ApiRequests.Services
@using CleaningFrontend.ApiRequests.Model
@using Blazored.LocalStorage

<div class="auth-container">
    <div class="auth-form">
        <h2>Вход в систему</h2>
        <EditForm Model="@loginModel" OnValidSubmit="@HandleLogin">
            <div class="form-group">
                <label>Email</label>
                <InputText @bind-value="loginModel.Email" class="form-control" />
            </div>
            <div class="form-group">
                <label>Пароль</label>
                <InputText @bind-value="loginModel.Password" type="password" class="form-control" />
            </div>
            <button type="submit" class="btn-primary">Войти</button>
        </EditForm>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-message">@errorMessage</div>
        }
        <div class="auth-link">
            <a href="/register">Нет аккаунта? Зарегистрироваться</a>
        </div>
    </div>
</div>

@code {
    private AuthModel loginModel = new AuthModel();
    private string errorMessage = "";

    [Inject] protected UserApiService UserService { get; set; }
    [Inject] protected NavigationManager Navigation { get; set; }
    [Inject] protected ILocalStorageService LocalStorage { get; set; }

    private async Task HandleLogin()
    {
        var result = await UserService.Auth(loginModel.Email, loginModel.Password);
        if (result.status)
        {
            await LocalStorage.SetItemAsync("token", result.token);
            await LocalStorage.SetItemAsync("user", result.user);

            var landing = result.user?.Role_Id switch
            {
                1 => "/admin",
                2 => "/orders",
                3 => "/my-tasks",
                4 => "/my-orders",
                _ => "/profile"
            };
            Navigation.NavigateTo(landing, forceLoad: true);
        }
        else
        {
            errorMessage = result.error ?? "Ошибка входа";
        }
    }

    public class AuthModel
    {
        public string Email { get; set; }
        public string Password { get; set; }
    }
}
