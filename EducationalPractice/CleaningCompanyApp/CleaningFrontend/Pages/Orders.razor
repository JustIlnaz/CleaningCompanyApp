@page "/orders"
@using CleaningFrontend.ApiRequests.Services
@using CleaningFrontend.ApiRequests.Model
@using Blazored.LocalStorage

<div class="page-container">
    <div class="page-header">
        <h1>Заказы на уборку</h1>
        @if (UserRole == 1 || UserRole == 2)
        {
            <button class="btn-primary" @onclick="ShowCreateModal">Создать заказ</button>
        }
    </div>

    <div class="filters">
            <select @bind="statusFilter">
            <option value="">Все статусы</option>
            <option value="Новый">Новый</option>
            <option value="В работе">В работе</option>
            <option value="Завершен">Завершен</option>
            <option value="Отменен">Отменен</option>
        </select>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Клиент</th>
                <th>Объект</th>
                <th>Тип уборки</th>
                <th>Дата</th>
                <th>Статус</th>
                <th>Бригада</th>
                <th>Цена</th>
                <th>Статус оплаты</th>
                @if (UserRole == 1 || UserRole == 2)
                {
                    <th>Действия</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var order in filteredOrders)
            {
                <tr>
                    <td>@order.Id_Order</td>
                    <td>@order.ClientName</td>
                    <td>@order.ObjectAddress</td>
                    <td>@order.CleaningType</td>
                    <td>@order.ScheduledDate.ToString("dd.MM.yyyy")</td>
                    <td><span class="@GetStatusClass(order.Status)">@order.Status</span></td>
                    <td>@order.BrigadeName</td>
                    <td>@order.Price.ToString("C")</td>
                    <td><span class="@GetPaymentStatusClass(order.PaymentStatus)">@order.PaymentStatus</span></td>
                    @if (UserRole == 1 || UserRole == 2)
                    {
                        <td>
                            <button class="btn-secondary" @onclick="() => EditOrder(order)">Изменить</button>
                            @if (order.BrigadeId == null)
                            {
                                <button class="btn-primary" @onclick="() => ShowAssignBrigadeModal(order)">Назначить бригаду</button>
                            }
                            <button class="@(order.PaymentStatus == "Оплачен" ? "btn-success" : "btn-warning")" @onclick="() => TogglePaymentStatus(order)">@(order.PaymentStatus == "Оплачен" ? "Оплачен" : "Отметить оплату")</button>
                            <button class="btn-danger" @onclick="() => DeleteOrder(order.Id_Order)">Удалить</button>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

@if (showModal)
{
    <div class="modal">
        <div class="modal-content">
            <h2>@(isEditing ? "Редактирование заказа" : "Создание заказа")</h2>
            <EditForm Model="@orderModel" OnValidSubmit="@SaveOrder">
                <div class="form-group">
                    <label>Дата выполнения</label>
                    <InputDate TValue="DateTime" @bind-Value="orderModel.ScheduledDate" class="form-control" />
                </div>
                <div class="form-group">
                    <label>Тип уборки</label>
                    <select @bind="orderModel.CleaningType" class="form-control">
                        <option value="Обычная">Обычная</option>
                        <option value="Генеральная">Генеральная</option>
                        <option value="После ремонта">После ремонта</option>
                        <option value="Клининг окон">Клининг окон</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Цена</label>
                    <InputNumber TValue="double" @bind-Value="orderModel.Price" class="form-control" />
                </div>
                <div class="form-group">
                    <label>Статус</label>
                    <select @bind="orderModel.Status" class="form-control">
                        <option value="Новый">Новый</option>
                        <option value="В работе">В работе</option>
                        <option value="Завершен">Завершен</option>
                        <option value="Отменен">Отменен</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Бригада</label>
                    <select @bind="orderModel.BrigadeId" class="form-control">
                        <option value="">-- не назначена --</option>
                        @foreach (var b in brigades)
                        {
                            <option value="@b.Id_Brigade">@b.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Статус оплаты</label>
                    <select @bind="orderModel.PaymentStatus" class="form-control">
                        <option value="Не оплачен">Не оплачен</option>
                        <option value="Оплачен">Оплачен</option>
                        <option value="Ожидает оплаты">Ожидает оплаты</option>
                    </select>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn-primary">Сохранить</button>
                    <button type="button" class="btn-secondary" @onclick="() => showModal = false">Отмена</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (showAssignModal)
{
    <div class="modal">
        <div class="modal-content">
            <h2>Назначить бригаду на заказ #@assignOrder.Id_Order</h2>
            <div class="form-group">
                <label>Бригада</label>
                <select @bind="selectedBrigadeId" class="form-control">
                    <option value="">-- выберите бригаду --</option>
                    @foreach (var b in brigades)
                    {
                        <option value="@b.Id_Brigade">@b.Name</option>
                    }
                </select>
            </div>
            <div class="form-actions">
                <button class="btn-primary" @onclick="SaveAssignBrigade">Назначить</button>
                <button type="button" class="btn-secondary" @onclick="() => showAssignModal = false">Отмена</button>
            </div>
        </div>
    </div>
}

@code {
    private List<OrderModel> orders = new List<OrderModel>();
    private List<OrderModel> filteredOrders = new List<OrderModel>();
    private string statusFilter = "";
    private bool showModal = false;
    private bool isEditing = false;
    private OrderModel orderModel = new OrderModel();
    private int UserRole = 0;
    private List<BrigadeModel> brigades = new List<BrigadeModel>();
    private bool showAssignModal = false;
    private OrderModel assignOrder = new OrderModel();
    private int? selectedBrigadeId = null;

    [Inject] protected OrderApiService OrderService { get; set; }
    [Inject] protected BrigadeApiService BrigadeService { get; set; }
    [Inject] protected HttpClient HttpClient { get; set; }
    [Inject] protected NavigationManager Navigation { get; set; }
    [Inject] protected ILocalStorageService LocalStorage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var token = await LocalStorage.GetItemAsync<string>("token");
        if (string.IsNullOrEmpty(token))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        var user = await LocalStorage.GetItemAsync<UserModel>("user");
        UserRole = user?.Role_Id ?? 0;

        orders = await OrderService.GetAllOrders(token);
        filteredOrders = orders;
        brigades = await BrigadeService.GetAllBrigades(token);
    }

    private void FilterOrders()
    {
        filteredOrders = string.IsNullOrEmpty(statusFilter) 
            ? orders 
            : orders.Where(o => o.Status == statusFilter).ToList();
    }

    private void ShowCreateModal()
    {
        isEditing = false;
        orderModel = new OrderModel();
        showModal = true;
    }

    private void EditOrder(OrderModel order)
    {
        isEditing = true;
        orderModel = new OrderModel
        {
            Id_Order = order.Id_Order,
            ScheduledDate = order.ScheduledDate,
            CleaningType = order.CleaningType,
            Price = order.Price,
            Status = order.Status,
            PaymentStatus = order.PaymentStatus,
            ObjectId = order.ObjectId,
            ObjectAddress = order.ObjectAddress,
            BrigadeId = order.BrigadeId,
            BrigadeName = order.BrigadeName,
            ClientId = order.ClientId,
            ClientName = order.ClientName
        };
        showModal = true;
    }

    private async Task SaveOrder()
    {
        var token = await LocalStorage.GetItemAsync<string>("token");

        bool success;
        if (isEditing)
        {
            success = await OrderService.UpdateOrder(orderModel, token);
        }
        else
        {
            success = await OrderService.CreateOrder(orderModel, token);
        }

        if (success)
        {
            orders = await OrderService.GetAllOrders(token);
            filteredOrders = orders;
            showModal = false;
        }
    }

    private async Task DeleteOrder(int id)
    {
        var token = await LocalStorage.GetItemAsync<string>("token");
        await OrderService.DeleteOrder(id, token);
        orders = await OrderService.GetAllOrders(token);
        filteredOrders = orders;
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Новый" => "status-new",
            "В работе" => "status-progress",
            "Завершен" => "status-completed",
            "Отменен" => "status-cancelled",
            _ => ""
        };
    }

    private string GetPaymentStatusClass(string paymentStatus)
    {
        return paymentStatus switch
        {
            "Оплачен" => "status-completed",
            "Не оплачен" => "status-cancelled",
            "Ожидает оплаты" => "status-progress",
            _ => ""
        };
    }

    private void ShowAssignBrigadeModal(OrderModel order)
    {
        assignOrder = order;
        selectedBrigadeId = order.BrigadeId;
        showAssignModal = true;
    }

    private async Task SaveAssignBrigade()
    {
        if (selectedBrigadeId.HasValue)
        {
            var token = await LocalStorage.GetItemAsync<string>("token");
            var success = await OrderService.AssignBrigade(assignOrder.Id_Order, selectedBrigadeId.Value, token);
            if (success)
            {
                orders = await OrderService.GetAllOrders(token);
                filteredOrders = orders;
                showAssignModal = false;
            }
        }
    }

    private async Task TogglePaymentStatus(OrderModel order)
    {
        var newStatus = order.PaymentStatus == "Оплачен" ? "Не оплачен" : "Оплачен";
        var token = await LocalStorage.GetItemAsync<string>("token");
        var updateModel = new OrderModel
        {
            Id_Order = order.Id_Order,
            ScheduledDate = order.ScheduledDate,
            CleaningType = order.CleaningType,
            Price = order.Price,
            Status = order.Status,
            PaymentStatus = newStatus,
            ObjectId = order.ObjectId,
            ObjectAddress = order.ObjectAddress,
            BrigadeId = order.BrigadeId,
            BrigadeName = order.BrigadeName,
            ClientId = order.ClientId,
            ClientName = order.ClientName
        };
        var success = await OrderService.UpdateOrder(updateModel, token);
        if (success)
        {
            order.PaymentStatus = newStatus;
            orders = await OrderService.GetAllOrders(token);
            filteredOrders = orders;
        }
    }
}
